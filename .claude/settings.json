{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && bash .scripts/check-console-logs.sh 2>&1; bash .scripts/check-html-syntax.sh 2>&1; bash .scripts/check-www-sync.sh 2>&1"
          }
        ]
      }
    ]
  }
}
