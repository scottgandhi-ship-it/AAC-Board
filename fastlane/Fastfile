default_platform(:ios)

platform :ios do

  # REST-based latest-build lookup. Avoids fastlane's default spaceship
  # call which hits the legacy iTunes Connect endpoint and can fail with
  # "A required agreement is missing or has expired" even when the actual
  # paid-apps agreement is in effect. Returns highest CFBundleVersion of
  # any uploaded build for the given bundle id (0 if none).
  def fetch_latest_build_via_rest(app_identifier:)
    require "jwt"
    require "net/http"
    require "json"

    key_data = File.read(File.join(ENV["PWD"], ENV["ASC_KEY_PATH"]))
    ec_key = OpenSSL::PKey::EC.new(key_data)
    now = Time.now.to_i
    payload = { iss: ENV["ASC_ISSUER_ID"], iat: now, exp: now + 1200, aud: "appstoreconnect-v1" }
    token = JWT.encode(payload, ec_key, "ES256", { kid: ENV["ASC_KEY_ID"] })
    headers = { "Authorization" => "Bearer #{token}" }

    uri = URI("https://api.appstoreconnect.apple.com/v1/apps?filter[bundleId]=#{app_identifier}&fields[apps]=bundleId")
    req = Net::HTTP::Get.new(uri, headers)
    res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    app_data = JSON.parse(res.body)["data"]
    UI.user_error!("No ASC app found for bundle id #{app_identifier}") if app_data.nil? || app_data.empty?
    app_id = app_data[0]["id"]

    uri = URI("https://api.appstoreconnect.apple.com/v1/builds?filter[app]=#{app_id}&sort=-uploadedDate&limit=1&fields[builds]=version")
    req = Net::HTTP::Get.new(uri, headers)
    res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    builds = JSON.parse(res.body)["data"]
    return 0 if builds.nil? || builds.empty?
    builds[0]["attributes"]["version"].to_i
  end

  # Shared helper: wait for build processing, submit beta review, distribute to external group
  def distribute_to_external(api_key:, app_identifier:, build_number:)
    require "jwt"
    require "net/http"
    require "json"

    # Generate a fresh ASC API token
    key_data = File.read(File.join(ENV["PWD"], ENV["ASC_KEY_PATH"]))
    ec_key = OpenSSL::PKey::EC.new(key_data)
    now = Time.now.to_i
    payload = { iss: ENV["ASC_ISSUER_ID"], iat: now, exp: now + 1200, aud: "appstoreconnect-v1" }
    token = JWT.encode(payload, ec_key, "ES256", { kid: ENV["ASC_KEY_ID"] })

    base = "https://api.appstoreconnect.apple.com/v1"
    headers = { "Authorization" => "Bearer #{token}", "Content-Type" => "application/json" }

    # Look up the app ID
    uri = URI("#{base}/apps?filter[bundleId]=#{app_identifier}&fields[apps]=bundleId")
    req = Net::HTTP::Get.new(uri, headers)
    res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    app_id = JSON.parse(res.body)["data"][0]["id"]

    # Find the build by version number (retry — build may not appear immediately after upload)
    build_data = nil
    uri = URI("#{base}/builds?filter[app]=#{app_id}&filter[version]=#{build_number}&limit=1")
    20.times do |attempt|
      req = Net::HTTP::Get.new(uri, headers)
      res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
      build_data = JSON.parse(res.body)["data"]&.first
      break if build_data
      UI.message("Build #{build_number} not yet visible in ASC (attempt #{attempt + 1}/20) — waiting 30s...")
      sleep(30)
    end
    UI.user_error!("Build #{build_number} never appeared in App Store Connect after 10 minutes") unless build_data
    build_id = build_data["id"]
    UI.message("Found build #{build_number} (#{build_id})")

    # Wait for processing if needed
    30.times do
      state = build_data["attributes"]["processingState"]
      break if state == "VALID"
      UI.message("Build processing state: #{state} — waiting 30s...")
      sleep(30)
      req = Net::HTTP::Get.new(uri, headers)
      res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
      build_data = JSON.parse(res.body)["data"][0]
    end
    UI.error("Build did not finish processing") unless build_data["attributes"]["processingState"] == "VALID"

    # Submit for beta app review
    body = {
      data: {
        type: "betaAppReviewSubmissions",
        relationships: { build: { data: { type: "builds", id: build_id } } }
      }
    }.to_json
    uri = URI("#{base}/betaAppReviewSubmissions")
    req = Net::HTTP::Post.new(uri, headers)
    req.body = body
    res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    review_response = JSON.parse(res.body)
    if review_response["data"]
      review_state = review_response["data"]["attributes"]["betaReviewState"]
      UI.message("Beta review submitted: #{review_state}")
    else
      detail = review_response.dig("errors", 0, "detail") || "unknown"
      if detail.include?("already exists")
        UI.message("Beta review already submitted")
      else
        UI.important("Beta review submission note: #{detail}")
      end
    end

    # Find external beta group
    uri = URI("#{base}/apps/#{app_id}/betaGroups")
    req = Net::HTTP::Get.new(uri, headers)
    res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    groups = JSON.parse(res.body)["data"]
    external_group = groups.find { |g| g["attributes"]["isInternalGroup"] == false }

    if external_group
      group_name = external_group["attributes"]["name"]
      group_id = external_group["id"]

      # Add build to external group
      body = { data: [{ type: "betaGroups", id: group_id }] }.to_json
      uri = URI("#{base}/builds/#{build_id}/relationships/betaGroups")
      req = Net::HTTP::Post.new(uri, headers)
      req.body = body
      res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
      UI.success("Build #{build_number} assigned to external group '#{group_name}' — testers will be notified!")
    else
      UI.important("No external beta group found — skipping distribution")
    end
  end

  desc "Build AAC Board, upload to TestFlight, and distribute to external testers"
  lane :aacboard do
    # Sync web assets and iOS project
    sh("cd #{ENV['PWD']} && npm run sync")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.join(ENV["PWD"], ENV["ASC_KEY_PATH"]),
    )

    # Auto-increment build number
    current = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.lussier.aacboard",
    )
    new_build = current + 1
    increment_build_number(
      build_number: new_build,
      xcodeproj: "ios/App/App.xcodeproj",
    )
    UI.message("AAC Board build number: #{new_build}")

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/aacboard",
      output_name: "AACBoard.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )

    UI.success("AAC Board #{new_build} uploaded to TestFlight!")

    # Auto-distribute to external testers
    distribute_to_external(
      api_key: api_key,
      app_identifier: "com.lussier.aacboard",
      build_number: new_build,
    )
  end

  desc "Build Guiding Steps, upload to TestFlight, and distribute to external testers"
  lane :guidingsteps do
    guiding_steps_dir = File.join(ENV["PWD"], "guiding-steps")

    # Sync web assets and iOS project for Guiding Steps
    sh("cd #{guiding_steps_dir} && npm run sync")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.join(ENV["PWD"], ENV["ASC_KEY_PATH"]),
    )

    # Auto-increment build number via ASC REST API (bypasses legacy iTunes
    # Connect endpoint that sometimes blocks on outdated paid-apps agreement).
    new_build = fetch_latest_build_via_rest(
      app_identifier: "com.lussier.guidingsteps"
    ) + 1
    increment_build_number(
      build_number: new_build,
      xcodeproj: File.join(guiding_steps_dir, "ios/App/App.xcodeproj"),
    )
    UI.message("Guiding Steps build number: #{new_build}")

    build_app(
      project: File.join(guiding_steps_dir, "ios/App/App.xcodeproj"),
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/guidingsteps",
      output_name: "GuidingSteps.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.lussier.guidingsteps",
      skip_waiting_for_build_processing: true,
    )

    UI.success("Guiding Steps #{new_build} uploaded to TestFlight!")

    # Auto-distribute to external testers
    distribute_to_external(
      api_key: api_key,
      app_identifier: "com.lussier.guidingsteps",
      build_number: new_build,
    )
  end

  desc "Build Yappie Adult, upload to TestFlight, and distribute to external testers"
  lane :yappieadult do
    yappie_adult_dir = File.join(ENV["PWD"], "yappie-adult")

    # Sync web assets and iOS project for Yappie Adult
    sh("cd #{yappie_adult_dir} && bash sync-www.sh && npx cap sync ios")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.join(ENV["PWD"], ENV["ASC_KEY_PATH"]),
    )

    # Auto-increment build number
    current = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.lussier.yappieadult",
    )
    new_build = current + 1
    increment_build_number(
      build_number: new_build,
      xcodeproj: File.join(yappie_adult_dir, "ios/App/App.xcodeproj"),
    )
    UI.message("Yappie Adult build number: #{new_build}")

    build_app(
      project: File.join(yappie_adult_dir, "ios/App/App.xcodeproj"),
      scheme: "App",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "2H6JBS4JF8",
      },
      output_directory: "build/yappieadult",
      output_name: "YappieAdult.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates",
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.lussier.yappieadult",
      skip_waiting_for_build_processing: true,
    )

    UI.success("Yappie Adult #{new_build} uploaded to TestFlight!")

    # Auto-distribute to external testers
    distribute_to_external(
      api_key: api_key,
      app_identifier: "com.lussier.yappieadult",
      build_number: new_build,
    )
  end

  desc "Build and upload all apps to TestFlight"
  lane :both do
    aacboard
    guidingsteps
  end

end
